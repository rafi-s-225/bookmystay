<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>  
<body>

    <h3>Edit your Listing</h3>
    <form method="POST" action="/listings/<%= listing.id %>?_method=PUT">
        <input name="listing[title]" value="<%= listing.title %>" placeholder="enter your name" type="text">
        <br>
        <textarea name="listing[description]" placeholder="enter description" value="<%= listing.description %>"type="text"></textarea>
        <br>
        <input name="listing[image]" placeholder="enter image URL/link" value="<%= listing.image.url %>"type="text">
        <br>
        <input name="listing[country]" value="<%= listing.country %>"placeholder="enter country" type="text">
        <br>
        <input name="listing[location]" placeholder="enter location" value="<%= listing.location %>"type="text">
        <br>
        <input name="listing[price]" value="<%= listing.price %>"placeholder="enter price" type="number">
        <br>
        <br>
        <button>submit</button>
</body>
</html>