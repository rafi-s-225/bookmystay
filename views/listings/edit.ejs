<% layout("/layouts/boilerplate") %>
<body>
  
    <h3>Edit your Listing</h3>

    <div class="row mt-3">
        <div class="col-8 offset-2" >
    <form method="POST" action="/listings/<%= listing.id %>?_method=PUT">
        <div class="mb-3">

            <label for="title" class="form-label"></label>
            <input name="listing[title]" value="<%= listing.title %>" placeholder="enter your name" type="text" class="form-control">
        </div>
        <div class="mb-3">
             <label for="description" class="form-label"></label>
            <textarea name="listing[description]" placeholder="enter description" value="<%= listing.description %>"type="text" class="form-control"></textarea>
        </div>
        <div class="mb-3">
             <label for="image" class="form-label"></label>
            <input name="listing[image]" placeholder="enter image URL/link" value="<%= listing.image.url %>"type="text" class="form-control">
        </div>
        <div class="row">
            <div class="mb-3" class="col-md-4">
                <label for="price" class="form-label"></label>
                <input name="listing[price]" value="<%= listing.price %>"placeholder="enter price" type="number" class="form-control">
            </div>
            <div class="mb-3">
                <label for="country" class="form-label"></label>
                <input name="listing[country]" value="<%= listing.country %>"placeholder="enter country" type="text" class="form-control">
            </div>
        </div>
        <div class="mb-3" class="col-md-8">
             <label for="location" class="form-label"></label>
            <input name="listing[location]" placeholder="enter location" value="<%= listing.location %>"type="text" class="form-control">
        </div>
        <button class="btn btn-dark edit-btn">Edit</button>
        </div>
    </div>
</body>