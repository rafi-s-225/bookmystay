<% layout("/layouts/boilerplate") %>

    <body>
        <div class="container mt-5">
            <div class="row mb-4">
                <div class="col-8 offset-2">
                    <h3><b><%= listing.title %></b></h3>
                </div>
            </div>
            
            <div class="row mb-4">
                <div class="col-8 offset-2">
                    <div class="show-card card listing-card">
                        <img src="<%=listing.image%>" alt="ListingImage" class="card-img-top show-img" />
                        <div class="card-body">
                            <p class="card-text">
                                <%= listing.description %><br />
                                &#8377; <%= listing.price.toLocaleString("en-IN") %><br />
                                <%= listing.location %><br />
                                <%= listing.country %><br />
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-8 offset-2">
                    <div class="btns d-flex gap-2">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>
                        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                            <button class="btn btn-dark">Delete</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-8 offset-2">
                    <h4>Leave a Review</h4>
                    <form class="needs-validation mb-4" method="POST" action="/listings/<%= listing._id %>/reviews" novalidate>
                        <div class="mb-3 mt-3">
                            <label for="rating" class="form-label">Rating</label>
                            <input type="range" min="1" max="5" value="3" name="review[rating]" id="rating" class="form-range" required>
                            <div class="invalid-feedback">
                                Please select a rating between 1 and 5.
                            </div>
                        </div>
                        <div class="mb-3 mt-3">
                            <label for="comment" class="form-label">Comments</label>
                            <textarea name="review[comment]" id="comment" cols="30" rows="8" class="form-control" required></textarea>
                            <div class="invalid-feedback">
                                Please enter your review comments.
                            </div>
                        </div>
                        <button class="btn btn-dark" type="submit">Submit</button>
                    </form>
                    
                    <h5 class="mb-3"><b>All Reviews</b></h5>
                    <% if (listing.reviews && listing.reviews.length > 0) { %>
                        <div class="row g-3 mb-5">
                            <% for(review of listing.reviews){%>
                                <div class="col-md-6">
                                    <div class="card listing-card h-100">
                                        <div class="card-body">
                                            <h5 class="card-title">John Doe</h5>
                                            <p class="card-text"><%= review.comment %></p>
                                            <p class="card-text"><small class="text-muted">Rating: <%= review.rating %>/5</small></p>
                                        </div>
                                        <form class="p-3 pt-0" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                            <button class="btn btn-sm btn-dark">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    <% } else { %>
                        <div class="alert alert-secondary mb-5" role="alert">
                            No reviews yet. Be the first to leave one!
                        </div>
                    <% } %>
                </div>
            </div>
        </div> 